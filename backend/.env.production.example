# ── Base de datos (Neon PostgreSQL) ──────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.us-east-1.aws.neon.tech/contadormx?ssl=require

# ── Redis (Upstash) ───────────────────────────────────────────────────────────
REDIS_URL=rediss://default:token@xxx.upstash.io:6379

# ── Qdrant Cloud ──────────────────────────────────────────────────────────────
QDRANT_URL=https://xxx.us-east4-0.gcp.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key

# ── IA / LLM ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
VOYAGE_API_KEY=pa-...
EMBEDDING_PROVIDER=voyage

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_min_32_chars
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Notificaciones ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@contadormx.mx

# ── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_AGENCIA=price_...
FRONTEND_URL=https://contadormx.vercel.app

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["https://contadormx.vercel.app","https://app.contadormx.mx"]

# ── Sentry (opcional) ────────────────────────────────────────────────────────
SENTRY_DSN=https://xxx@sentry.io/xxx
